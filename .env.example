# ── OANDA API ─────────────────────────────────────────────────────────────────
# Get these from https://www.oanda.com/demo-account/ (practice) or your live account
OANDA_ACCOUNT_ID=your-oanda-account-id
OANDA_ACCESS_TOKEN=your-oanda-access-token

# Comma-separated list of currency pairs to trade
TRADING_INSTRUMENTS=EUR_USD,GBP_USD,USD_JPY,USD_CHF,AUD_USD,NZD_USD,USD_CAD

# ── FastAPI / JWT ─────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_at_least_64_random_hex_characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Default admin seed user ───────────────────────────────────────────────────
# Created automatically on first startup — change before deploying!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
